# Optional session environment overrides for boot-video-player.service.
# Leave this file unchanged if auto-detection works in your setup.
#
# Common Arch + SDDM (X11) example:
# DISPLAY=:0
# XDG_RUNTIME_DIR=/run/user/120
# XAUTHORITY=/var/lib/sddm/.Xauthority
#
# Wayland example:
# DISPLAY=:0
# XDG_RUNTIME_DIR=/run/user/1000
# WAYLAND_DISPLAY=wayland-0
# XAUTHORITY=/run/user/1000/gdm/Xauthority
